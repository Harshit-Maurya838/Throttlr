# Application Port
PORT=3000

# Docker PostgreSQL Configuration
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=rate_limiter_db
POSTGRES_PORT=54321

# Docker Redis Configuration
REDIS_PORT=63799

# Service Connection Strings (swap with managed host strings in production)
# In local development using docker-compose, postgres maps to localhost:POSTGRES_PORT
# and redis maps to localhost:REDIS_PORT.
# If running containers in the same docker network, you would use container names.
# Here we use host port mapping so that running the node app outside of docker matches.
DATABASE_URL="postgresql://postgres_user:postgres_secure_pass@localhost:54321/rate_limiter_db?schema=public"
REDIS_URL="redis://localhost:63799"
